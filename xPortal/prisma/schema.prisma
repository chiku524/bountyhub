// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @map("_id") @default(auto()) @db.ObjectId
  email     String   @unique
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  profile   Profile?
  posts     Posts[]
  comments  Comment[]
  answers   Answer[]
  votes     Vote[]
  reputationPoints Int @default(0)
  reputationHistory ReputationHistory[]
}

model Profile {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String   @unique @db.ObjectId
  firstName     String?  @db.String
  lastName      String?  @db.String
  profilePicture String? @db.String
  bio           String?  @db.String
  location      String?  @db.String
  website       String?  @db.String
  // Social Media Links
  facebook      String?  @db.String
  twitter       String?  @db.String
  instagram     String?  @db.String
  linkedin      String?  @db.String
  github        String?  @db.String
  youtube       String?  @db.String
  tiktok        String?  @db.String
  discord       String?  @db.String
  reddit        String?  @db.String
  medium        String?  @db.String
  stackoverflow String?  @db.String
  devto         String?  @db.String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model Media {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  type              String   // IMAGE, VIDEO, AUDIO
  url               String
  thumbnailUrl      String?
  isScreenRecording Boolean  @default(false)
  cloudinaryId      String
  post              Posts    @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId            String   @db.ObjectId
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("media")
}

model Posts {
  id          String   @id @map("_id") @default(auto()) @db.ObjectId
  title       String
  content     String
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId    String   @db.ObjectId
  media       Media[]
  codeBlocks  CodeBlock[]
  comments    Comment[]
  answers     Answer[]
  votes       Vote[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  visibilityVotes Int @default(0)
  qualityUpvotes Int @default(0)
  qualityDownvotes Int @default(0)

  @@index([authorId])
  @@index([createdAt])
  @@map("posts")
}

model Comment {
  id String @id @map("_id") @default(auto()) @db.ObjectId
  content String
  authorId String @db.ObjectId
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)
  postId String @db.ObjectId
  post Posts @relation(fields: [postId], references: [id], onDelete: Cascade)
  answerId String? @db.ObjectId
  answer Answer? @relation(fields: [answerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  votes Vote[]
  upvotes Int @default(0)
  downvotes Int @default(0)

  @@index([postId])
  @@index([authorId])
  @@index([createdAt])
}

model Answer {
  id String @id @map("_id") @default(auto()) @db.ObjectId
  content String
  authorId String @db.ObjectId
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)
  postId String @db.ObjectId
  post Posts @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  comments Comment[]
  votes Vote[]
  upvotes Int @default(0)
  downvotes Int @default(0)
  isAccepted Boolean @default(false)

  @@index([postId])
  @@index([authorId])
  @@index([createdAt])
  @@index([isAccepted])
}

enum VoteType {
  POST
  COMMENT
  ANSWER
}

model Vote {
  id           String   @id @map("_id") @default(auto()) @db.ObjectId
  userId       String   @db.ObjectId
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId       String?  @db.ObjectId
  post         Posts?   @relation(fields: [postId], references: [id], onDelete: Cascade)
  commentId    String?  @db.ObjectId
  comment      Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  answerId     String?  @db.ObjectId
  answer       Answer?  @relation(fields: [answerId], references: [id], onDelete: Cascade)
  value        Int
  voteType     String
  isQualityVote Boolean
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId, commentId], name: "user_comment_idx")
  @@index([userId, answerId], name: "user_answer_idx")
  @@index([userId, postId], name: "user_post_idx")
}

model CodeBlock {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  language  String
  code      String
  post      Posts    @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId    String   @db.ObjectId
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ReputationHistory {
  id String @id @map("_id") @default(auto()) @db.ObjectId
  userId String @db.ObjectId
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  points Int
  action String // e.g., 'POST_CREATED', 'ANSWER_ACCEPTED', 'COMMENT_UPVOTED'
  referenceId String? @db.ObjectId // ID of the related post/comment/answer
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([action])
}