// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @map("_id") @default(auto()) @db.ObjectId
  email     String   @unique
  username  String   @unique
  password  String
  solanaAddress String? @unique // Generated Solana wallet address for this user
  tokenAccountAddress String? // Associated token account for PORTAL tokens
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  profile   Profile?
  posts     Posts[]
  comments  Comment[]
  answers   Answer[]
  votes     Vote[]
  bookmarks Bookmark[]
  reputationPoints Int @default(0)
  reputationHistory ReputationHistory[]
  bountyWinners Bounty[] @relation("BountyWinners")
  virtualWallet VirtualWallet?
  walletTransactions WalletTransaction[]
  // Integrity system fields
  integrityScore Float @default(5.0) // Average rating from 1-10
  totalRatings Int @default(0) // Total number of ratings received
  integrityViolations IntegrityViolation[] @relation("ViolationTarget")
  integrityHistory IntegrityHistory[] @relation("HistoryTarget")
  // Ratings given and received
  ratingsGiven UserRating[] @relation("RatingGiver")
  ratingsReceived UserRating[] @relation("RatingReceiver")
  // Refund request relations
  refundRequests RefundRequest[] @relation("RefundRequesters")
  refundRequestVotes RefundRequestVote[] @relation("RefundRequestVoters")
}

model Profile {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String   @unique @db.ObjectId
  firstName     String?  @db.String
  lastName      String?  @db.String
  profilePicture String? @db.String
  bio           String?  @db.String
  location      String?  @db.String
  website       String?  @db.String
  // Social Media Links
  facebook      String?  @db.String
  twitter       String?  @db.String
  instagram     String?  @db.String
  linkedin      String?  @db.String
  github        String?  @db.String
  youtube       String?  @db.String
  tiktok        String?  @db.String
  discord       String?  @db.String
  reddit        String?  @db.String
  medium        String?  @db.String
  stackoverflow String?  @db.String
  devto         String?  @db.String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model Media {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  type              String   // IMAGE, VIDEO, AUDIO
  url               String
  thumbnailUrl      String?
  isScreenRecording Boolean  @default(false)
  cloudinaryId      String
  post              Posts    @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId            String   @db.ObjectId
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("media")
}

model Posts {
  id          String   @id @map("_id") @default(auto()) @db.ObjectId
  title       String
  content     String
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId    String   @db.ObjectId
  media       Media[]
  codeBlocks  CodeBlock[]
  comments    Comment[]
  answers     Answer[]
  votes       Vote[]
  postTags    PostTag[]
  bookmarks   Bookmark[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  visibilityVotes Int @default(0)
  qualityUpvotes Int @default(0)
  qualityDownvotes Int @default(0)
  hasBounty   Boolean   @default(false)
  bounty      Bounty?
  status      PostStatus @default(OPEN)

  @@index([authorId])
  @@index([createdAt])
  @@map("posts")
}

model Comment {
  id String @id @map("_id") @default(auto()) @db.ObjectId
  content String
  authorId String @db.ObjectId
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)
  postId String @db.ObjectId
  post Posts @relation(fields: [postId], references: [id], onDelete: Cascade)
  answerId String? @db.ObjectId
  answer Answer? @relation(fields: [answerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  votes Vote[]
  upvotes Int @default(0)
  downvotes Int @default(0)

  @@index([postId])
  @@index([authorId])
  @@index([createdAt])
}

model Answer {
  id String @id @map("_id") @default(auto()) @db.ObjectId
  content String
  authorId String @db.ObjectId
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)
  postId String @db.ObjectId
  post Posts @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  comments Comment[]
  votes Vote[]
  upvotes Int @default(0)
  downvotes Int @default(0)
  isAccepted Boolean @default(false)

  @@index([postId])
  @@index([authorId])
  @@index([createdAt])
  @@index([isAccepted])
}

enum VoteType {
  POST
  COMMENT
  ANSWER
}

model Vote {
  id           String   @id @map("_id") @default(auto()) @db.ObjectId
  userId       String   @db.ObjectId
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId       String?  @db.ObjectId
  post         Posts?   @relation(fields: [postId], references: [id], onDelete: Cascade)
  commentId    String?  @db.ObjectId
  comment      Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  answerId     String?  @db.ObjectId
  answer       Answer?  @relation(fields: [answerId], references: [id], onDelete: Cascade)
  value        Int
  voteType     String
  isQualityVote Boolean
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId, commentId], name: "user_comment_idx")
  @@index([userId, answerId], name: "user_answer_idx")
  @@index([userId, postId], name: "user_post_idx")
}

model CodeBlock {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  language    String
  code        String
  description String?  // Optional description for the code block
  post        Posts    @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId      String   @db.ObjectId
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ReputationHistory {
  id String @id @map("_id") @default(auto()) @db.ObjectId
  userId String @db.ObjectId
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  points Int
  action String // e.g., 'POST_CREATED', 'ANSWER_ACCEPTED', 'COMMENT_UPVOTED'
  referenceId String? @db.ObjectId // ID of the related post/comment/answer
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([action])
}

model Bounty {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  postId        String    @db.ObjectId
  post          Posts     @relation(fields: [postId], references: [id], onDelete: Cascade)
  amount        Float     // Amount in SOL
  status        BountyStatus @default(ACTIVE)
  winnerId      String?   @db.ObjectId // ID of the user who won the bounty
  winner        User?     @relation("BountyWinners", fields: [winnerId], references: [id], onDelete: SetNull)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  expiresAt     DateTime? // Optional expiration date
  signature     String?   // Solana transaction signature
  mintAddress   String?   // SPL token mint address if using custom tokens
  tokenDecimals Int      @default(9) // Default to 9 for SOL, can be different for SPL tokens
  walletTransactions WalletTransaction[]
  
  // Time-based refund restrictions
  refundLockPeriod Int @default(24) // Hours after first answer before refund is allowed
  firstAnswerAt DateTime? // When first answer was received
  refundReason String? // Required reason for refund
  refundPenalty Float @default(0) // Penalty amount for refunding
  
  // Community approval system
  refundRequests RefundRequest[]
  communityFee Float @default(0.05) // 5% fee for community governance

  @@unique([postId])
  @@index([winnerId])
  @@map("bounties")
}

enum BountyStatus {
  ACTIVE
  CLAIMED
  REFUNDED
  EXPIRED
}

enum RefundRequestStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

enum PostStatus {
  OPEN
  CLOSED
  COMPLETED
}

model VirtualWallet {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String   @unique @db.ObjectId
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance       Float    @default(0) // Virtual balance in SOL
  totalDeposited Float   @default(0) // Total amount ever deposited
  totalWithdrawn Float   @default(0) // Total amount ever withdrawn
  totalEarned   Float    @default(0) // Total amount earned from bounties
  totalSpent    Float    @default(0) // Total amount spent on bounties
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  transactions  WalletTransaction[]

  @@map("virtual_wallets")
}

model WalletTransaction {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String   @db.ObjectId
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  walletId      String   @db.ObjectId
  wallet        VirtualWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  type          TransactionType
  amount        Float
  balanceBefore Float
  balanceAfter  Float
  description   String
  status        TransactionStatus @default(PENDING)
  solanaSignature String? // Solana transaction signature for deposits/withdrawals
  bountyId      String?  @db.ObjectId // Reference to bounty if related
  bounty        Bounty?  @relation(fields: [bountyId], references: [id], onDelete: SetNull)
  metadata      String?  // JSON string with additional data (fees, net amounts, etc.)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@map("wallet_transactions")
}

enum TransactionType {
  DEPOSIT      // User deposits SOL from their wallet
  WITHDRAW     // User withdraws SOL to their wallet
  BOUNTY_CREATED // User creates a bounty
  BOUNTY_CLAIMED // User claims a bounty
  BOUNTY_REFUNDED // User gets refunded from expired bounty
  BOUNTY_EARNED // User earns from winning a bounty
  COMPENSATION // Compensation for governance participation or penalties
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

model TransactionLog {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  type          String   // DEPOSIT, WITHDRAWAL, BOUNTY_CREATED, BOUNTY_CLAIMED, etc.
  userId        String   @db.ObjectId
  amount        Float
  transactionId String   // Reference to the actual transaction
  timestamp     DateTime @default(now())
  status        String   // PENDING, COMPLETED, FAILED
  metadata      String?  // JSON string with additional data
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([type])
  @@index([timestamp])
  @@index([status])
  @@map("transaction_logs")
}

// Integrity System Models

model UserRating {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  raterId       String   @db.ObjectId // User giving the rating
  rater         User     @relation("RatingGiver", fields: [raterId], references: [id], onDelete: Cascade)
  ratedUserId   String   @db.ObjectId // User being rated
  ratedUser     User     @relation("RatingReceiver", fields: [ratedUserId], references: [id], onDelete: Cascade)
  rating        Int      // Rating from 1-10
  reason        String   // Reason for the rating
  context       String   // Context (e.g., "BOUNTY_REJECTION", "GENERAL", "ANSWER_QUALITY")
  referenceId   String?  @db.ObjectId // ID of related post/answer/bounty
  referenceType String?  // Type of reference (POST, ANSWER, BOUNTY)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([raterId, ratedUserId, referenceId]) // Prevent duplicate ratings for same context
  @@index([ratedUserId])
  @@index([raterId])
  @@index([context])
  @@index([createdAt])
  @@map("user_ratings")
}

model IntegrityViolation {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  reporterId    String   @db.ObjectId // User reporting the violation
  targetUserId  String   @db.ObjectId // User being reported
  targetUser    User     @relation("ViolationTarget", fields: [targetUserId], references: [id], onDelete: Cascade)
  violationType String   // Type of violation (BOUNTY_REJECTION, SPAM, HARASSMENT, etc.)
  description   String   // Description of the violation
  evidence      String?  // Evidence or proof (URLs, screenshots, etc.)
  referenceId   String?  @db.ObjectId // ID of related post/answer/bounty
  referenceType String?  // Type of reference
  status        ViolationStatus @default(PENDING) // PENDING, REVIEWED, RESOLVED, DISMISSED
  moderatorNotes String? // Notes from moderators
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([targetUserId])
  @@index([reporterId])
  @@index([violationType])
  @@index([status])
  @@index([createdAt])
  @@map("integrity_violations")
}

model IntegrityHistory {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String   @db.ObjectId
  user          User     @relation("HistoryTarget", fields: [userId], references: [id], onDelete: Cascade)
  action        String   // Action taken (RATING_RECEIVED, VIOLATION_REPORTED, etc.)
  points        Int      // Points gained/lost
  description   String   // Description of the action
  referenceId   String?  @db.ObjectId // ID of related rating/violation
  referenceType String?  // Type of reference
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("integrity_history")
}

enum ViolationStatus {
  PENDING
  REVIEWED
  RESOLVED
  DISMISSED
}

model Tag {
  id          String   @id @map("_id") @default(auto()) @db.ObjectId
  name        String   @unique
  description String?
  color       String   @default("#8B5CF6") // Default violet color
  postTags    PostTag[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("tags")
}

model PostTag {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  postId String @db.ObjectId
  tagId  String @db.ObjectId
  post   Posts  @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([postId, tagId])
  @@map("post_tags")
}

model Bookmark {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  postId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Posts    @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, postId])
  @@index([userId])
  @@index([postId])
  @@map("bookmarks")
}

model RefundRequest {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  bountyId String @db.ObjectId
  bounty Bounty @relation(fields: [bountyId], references: [id], onDelete: Cascade)
  requesterId String @db.ObjectId
  requester User @relation("RefundRequesters", fields: [requesterId], references: [id], onDelete: Cascade)
  reason String
  status RefundRequestStatus @default(PENDING)
  communityVotes Int @default(0) // Positive votes needed
  requiredVotes Int @default(5) // Minimum votes to approve
  createdAt DateTime @default(now())
  expiresAt DateTime // 48 hours to get votes
  votes RefundRequestVote[]
  
  @@index([bountyId])
  @@index([requesterId])
  @@index([status])
  @@index([expiresAt])
  @@map("refund_requests")
}

model RefundRequestVote {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  refundRequestId String @db.ObjectId
  refundRequest RefundRequest @relation(fields: [refundRequestId], references: [id], onDelete: Cascade)
  voterId String @db.ObjectId
  voter User @relation("RefundRequestVoters", fields: [voterId], references: [id], onDelete: Cascade)
  vote Boolean // true for approve, false for reject
  reason String?
  rewardAmount Float @default(0) // Reward for participating in governance
  createdAt DateTime @default(now())
  
  @@unique([refundRequestId, voterId]) // One vote per user per refund request
  @@index([refundRequestId])
  @@index([voterId])
  @@map("refund_request_votes")
}