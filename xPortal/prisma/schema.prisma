// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  profile   Profile?
  posts     Posts[]
  comments  Comment[]
  answers   Answer[]
  votes     Vote[]
  qualityVotes QualityVote[]
  reputationPoints Int @default(0)
  reputationHistory ReputationHistory[]
}

model Profile {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String   @unique @db.ObjectId
  firstName     String?  @db.String
  lastName      String?  @db.String
  profilePicture String? @db.String
  bio           String?  @db.String
  location      String?  @db.String
  website       String?  @db.String
  twitter       String?  @db.String
  github        String?  @db.String
  linkedin      String?  @db.String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Posts {
  id String   @id @map("_id") @default(auto()) @db.ObjectId
  authorId  String @db.ObjectId
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  title String
  content  String
  blobVideoURL String?
  codeBlocks CodeBlock[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  comments Comment[]
  answers Answer[]
  votes Vote[]
  qualityVotes QualityVote[]
  visibilityVotes Int @default(0) // For community visibility
  qualityUpvotes Int @default(0) // For quality assurance
  qualityDownvotes Int @default(0) // For quality assurance
}

model Comment {
  id String @id @map("_id") @default(auto()) @db.ObjectId
  content String
  authorId String @db.ObjectId
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)
  postId String @db.ObjectId
  post Posts @relation(fields: [postId], references: [id], onDelete: Cascade)
  answerId String? @db.ObjectId
  answer Answer? @relation(fields: [answerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  votes Vote[]
  upvotes Int @default(0)
  downvotes Int @default(0)
}

model Answer {
  id String @id @map("_id") @default(auto()) @db.ObjectId
  content String
  authorId String @db.ObjectId
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)
  postId String @db.ObjectId
  post Posts @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  comments Comment[]
  votes Vote[]
  upvotes Int @default(0)
  downvotes Int @default(0)
  isAccepted Boolean @default(false)
}

enum VoteType {
  POST
  COMMENT
  ANSWER
}

model Vote {
  id String @id @map("_id") @default(auto()) @db.ObjectId
  userId String @db.ObjectId
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  value Int // 1 for upvote, -1 for downvote
  postId String? @db.ObjectId
  post Posts? @relation(fields: [postId], references: [id], onDelete: Cascade)
  commentId String? @db.ObjectId
  comment Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  answerId String? @db.ObjectId
  answer Answer? @relation(fields: [answerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  voteType String @db.String // 'POST', 'COMMENT', or 'ANSWER'
  isQualityVote Boolean @default(false) // Indicates if this is a quality vote

  @@index([userId, voteType])
  @@unique([userId, postId, voteType, isQualityVote], map: "vote_post_unique")
  @@unique([userId, commentId, voteType], map: "vote_comment_unique")
  @@unique([userId, answerId, voteType], map: "vote_answer_unique")
}

model CodeBlock {
  id String @id @map("_id") @default(auto()) @db.ObjectId
  language String
  code String
  postId String @db.ObjectId
  post Posts @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model QualityVote {
  id String @id @map("_id") @default(auto()) @db.ObjectId
  userId String @db.ObjectId
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId String @db.ObjectId
  post Posts @relation(fields: [postId], references: [id], onDelete: Cascade)
  value Int // 1 for upvote, -1 for downvote
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, postId])
  @@index([userId])
  @@index([postId])
}

model ReputationHistory {
  id String @id @map("_id") @default(auto()) @db.ObjectId
  userId String @db.ObjectId
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  points Int
  action String // e.g., 'POST_CREATED', 'ANSWER_ACCEPTED', 'COMMENT_UPVOTED'
  referenceId String? @db.ObjectId // ID of the related post/comment/answer
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([action])
}