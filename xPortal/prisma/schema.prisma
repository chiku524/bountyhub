// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @map("_id") @default(auto()) @db.ObjectId
  email     String   @unique
  username  String   @unique
  password  String
  solanaAddress String? @unique // Generated Solana wallet address for this user
  tokenAccountAddress String? // Associated token account for PORTAL tokens
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  profile   Profile?
  posts     Posts[]
  comments  Comment[]
  answers   Answer[]
  votes     Vote[]
  reputationPoints Int @default(0)
  reputationHistory ReputationHistory[]
  bountyWinners Bounty[] @relation("BountyWinners")
  virtualWallet VirtualWallet?
  walletTransactions WalletTransaction[]
}

model Profile {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String   @unique @db.ObjectId
  firstName     String?  @db.String
  lastName      String?  @db.String
  profilePicture String? @db.String
  bio           String?  @db.String
  location      String?  @db.String
  website       String?  @db.String
  // Social Media Links
  facebook      String?  @db.String
  twitter       String?  @db.String
  instagram     String?  @db.String
  linkedin      String?  @db.String
  github        String?  @db.String
  youtube       String?  @db.String
  tiktok        String?  @db.String
  discord       String?  @db.String
  reddit        String?  @db.String
  medium        String?  @db.String
  stackoverflow String?  @db.String
  devto         String?  @db.String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model Media {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  type              String   // IMAGE, VIDEO, AUDIO
  url               String
  thumbnailUrl      String?
  isScreenRecording Boolean  @default(false)
  cloudinaryId      String
  post              Posts    @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId            String   @db.ObjectId
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("media")
}

model Posts {
  id          String   @id @map("_id") @default(auto()) @db.ObjectId
  title       String
  content     String
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId    String   @db.ObjectId
  media       Media[]
  codeBlocks  CodeBlock[]
  comments    Comment[]
  answers     Answer[]
  votes       Vote[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  visibilityVotes Int @default(0)
  qualityUpvotes Int @default(0)
  qualityDownvotes Int @default(0)
  hasBounty   Boolean   @default(false)
  bounty      Bounty?
  status      PostStatus @default(OPEN)

  @@index([authorId])
  @@index([createdAt])
  @@map("posts")
}

model Comment {
  id String @id @map("_id") @default(auto()) @db.ObjectId
  content String
  authorId String @db.ObjectId
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)
  postId String @db.ObjectId
  post Posts @relation(fields: [postId], references: [id], onDelete: Cascade)
  answerId String? @db.ObjectId
  answer Answer? @relation(fields: [answerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  votes Vote[]
  upvotes Int @default(0)
  downvotes Int @default(0)

  @@index([postId])
  @@index([authorId])
  @@index([createdAt])
}

model Answer {
  id String @id @map("_id") @default(auto()) @db.ObjectId
  content String
  authorId String @db.ObjectId
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)
  postId String @db.ObjectId
  post Posts @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  comments Comment[]
  votes Vote[]
  upvotes Int @default(0)
  downvotes Int @default(0)
  isAccepted Boolean @default(false)

  @@index([postId])
  @@index([authorId])
  @@index([createdAt])
  @@index([isAccepted])
}

enum VoteType {
  POST
  COMMENT
  ANSWER
}

model Vote {
  id           String   @id @map("_id") @default(auto()) @db.ObjectId
  userId       String   @db.ObjectId
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId       String?  @db.ObjectId
  post         Posts?   @relation(fields: [postId], references: [id], onDelete: Cascade)
  commentId    String?  @db.ObjectId
  comment      Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  answerId     String?  @db.ObjectId
  answer       Answer?  @relation(fields: [answerId], references: [id], onDelete: Cascade)
  value        Int
  voteType     String
  isQualityVote Boolean
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId, commentId], name: "user_comment_idx")
  @@index([userId, answerId], name: "user_answer_idx")
  @@index([userId, postId], name: "user_post_idx")
}

model CodeBlock {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  language  String
  code      String
  post      Posts    @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId    String   @db.ObjectId
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ReputationHistory {
  id String @id @map("_id") @default(auto()) @db.ObjectId
  userId String @db.ObjectId
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  points Int
  action String // e.g., 'POST_CREATED', 'ANSWER_ACCEPTED', 'COMMENT_UPVOTED'
  referenceId String? @db.ObjectId // ID of the related post/comment/answer
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([action])
}

model Bounty {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  postId        String    @db.ObjectId
  post          Posts     @relation(fields: [postId], references: [id], onDelete: Cascade)
  amount        Float     // Amount in SOL
  status        BountyStatus @default(ACTIVE)
  winnerId      String?   @db.ObjectId // ID of the user who won the bounty
  winner        User?     @relation("BountyWinners", fields: [winnerId], references: [id], onDelete: SetNull)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  expiresAt     DateTime? // Optional expiration date
  signature     String?   // Solana transaction signature
  mintAddress   String?   // SPL token mint address if using custom tokens
  tokenDecimals Int      @default(9) // Default to 9 for SOL, can be different for SPL tokens
  walletTransactions WalletTransaction[]

  @@unique([postId])
  @@index([winnerId])
  @@map("bounties")
}

enum BountyStatus {
  ACTIVE
  CLAIMED
  REFUNDED
  EXPIRED
}

enum PostStatus {
  OPEN
  CLOSED
  COMPLETED
}

model VirtualWallet {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String   @unique @db.ObjectId
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance       Float    @default(0) // Virtual balance in SOL
  totalDeposited Float   @default(0) // Total amount ever deposited
  totalWithdrawn Float   @default(0) // Total amount ever withdrawn
  totalEarned   Float    @default(0) // Total amount earned from bounties
  totalSpent    Float    @default(0) // Total amount spent on bounties
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  transactions  WalletTransaction[]

  @@map("virtual_wallets")
}

model WalletTransaction {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String   @db.ObjectId
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  walletId      String   @db.ObjectId
  wallet        VirtualWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  type          TransactionType
  amount        Float
  balanceBefore Float
  balanceAfter  Float
  description   String
  status        TransactionStatus @default(PENDING)
  solanaSignature String? // Solana transaction signature for deposits/withdrawals
  bountyId      String?  @db.ObjectId // Reference to bounty if related
  bounty        Bounty?  @relation(fields: [bountyId], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@map("wallet_transactions")
}

enum TransactionType {
  DEPOSIT      // User deposits SOL from their wallet
  WITHDRAW     // User withdraws SOL to their wallet
  BOUNTY_CREATED // User creates a bounty
  BOUNTY_CLAIMED // User claims a bounty
  BOUNTY_REFUNDED // User gets refunded from expired bounty
  BOUNTY_EARNED // User earns from winning a bounty
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

model TransactionLog {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  type          String   // DEPOSIT, WITHDRAWAL, BOUNTY_CREATED, BOUNTY_CLAIMED, etc.
  userId        String   @db.ObjectId
  amount        Float
  transactionId String   // Reference to the actual transaction
  timestamp     DateTime @default(now())
  status        String   // PENDING, COMPLETED, FAILED
  metadata      String?  // JSON string with additional data
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([type])
  @@index([timestamp])
  @@index([status])
  @@map("transaction_logs")
}