{
  "functions": {
    "app/routes/posts.create.tsx": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/posts/create",
      "destination": "/app/routes/posts.create.tsx"
    }
  ]
} 