# BountyHub frontend env (copy to .env.local — see README for Cloudflare Pages)
#
# GIPHY: create a key at https://developers.giphy.com/ (SDK / API key works with v1 REST).
# Required for Team Hub sidebar GIF search. Also set VITE_GIPHY_API_KEY in Cloudflare Pages.

VITE_API_URL=http://localhost:8788
VITE_GIPHY_API_KEY=
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
VITE_SOLANA_RPC_URL=
