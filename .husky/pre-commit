#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "🔍 Running pre-commit checks..."

# Run TypeScript type checking
echo "📝 Checking TypeScript types..."
npm run build:api 2>&1 | grep -E "(error TS|Failed)" && exit 1 || true

# Run frontend type checking
echo "📝 Checking frontend TypeScript..."
npx tsc --noEmit 2>&1 | grep -E "(error TS|Found [0-9]+ error)" && exit 1 || true

# Run linter
echo "🔍 Running linter..."
npm run lint 2>&1 | grep -E "(error|✖)" && exit 1 || true

echo "✅ All pre-commit checks passed!"

