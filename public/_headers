/*
  Cache-Control: public, max-age=0, must-revalidate
  X-Content-Type-Options: nosniff

# Logo and favicon: revalidate so updates show without hard refresh (versioned URLs also used for cache busting)
/logo.svg
  Cache-Control: public, max-age=0, must-revalidate
/favicon.svg
  Cache-Control: public, max-age=0, must-revalidate

# OG / social share image (must be publicly reachable for crawlers)
/og-image.jpg
  Cache-Control: public, max-age=86400
/og-image.png
  Cache-Control: public, max-age=86400

/assets/*
  Cache-Control: public, max-age=31536000, immutable

