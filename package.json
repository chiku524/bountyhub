{
  "name": "bountyhub",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "wrangler dev --config wrangler.dev.toml --persist-to .wrangler/state",
    "dev:frontend": "vite",
    "dev:full": "concurrently \"npm run dev:api\" \"npm run dev:frontend\"",
    "dev:setup": "./scripts/dev-setup.sh",
    "dev:setup:win": "scripts\\dev-setup.bat",
    "prebuild": "node -e \"require('os').platform()==='linux'&&require('child_process').execSync('npm install --no-save @rollup/rollup-linux-x64-gnu',{stdio:'inherit'})\" || true",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "typecheck:api": "tsc --noEmit --project functions/tsconfig.json",
    "typecheck:all": "npm run build && npm run typecheck:api",
    "build:api": "npm run typecheck:api",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "vite preview",
    "deploy:api": "wrangler deploy --config wrangler.workers.toml",
    "deploy:frontend": "wrangler pages deploy ./dist --project-name bountyhub",
    "deploy:frontend:local": "npm run build && wrangler pages deploy ./dist --project-name bountyhub",
    "deploy:workers": "wrangler deploy --config wrangler.workers.toml",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply bountyhub-db",
    "db:studio": "drizzle-kit studio",
    "tauri": "tauri",
    "desktop": "tauri dev",
    "desktop:build": "tauri build",
    "desktop:icons": "node scripts/generate-desktop-icons.js"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.31.1",
    "@solana/spl-token": "^0.4.13",
    "@solana/wallet-adapter-base": "^0.9.27",
    "@solana/wallet-adapter-phantom": "^0.9.28",
    "@solana/wallet-adapter-react": "^0.15.39",
    "@solana/wallet-adapter-react-ui": "^0.9.39",
    "@solana/wallet-adapter-solflare": "^0.6.32",
    "@solana/wallet-adapter-wallets": "^0.19.37",
    "@solana/web3.js": "^1.98.2",
    "@tauri-apps/api": "^1.6.0",
    "bcryptjs": "2.4.3",
    "cloudinary": "2.0.1",
    "drizzle-orm": "^0.44.2",
    "gsap": "3.12.5",
    "hono": "^4.8.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet-async": "^2.0.5",
    "react-icons": "5.0.1",
    "react-router-dom": "^6.22.0",
    "react-syntax-highlighter": "15.5.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250620.0",
    "@eslint/js": "^9.15.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@tauri-apps/cli": "^1.6.3",
    "@types/bcryptjs": "2.4.6",
    "@types/bs58": "^4.0.4",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/react-syntax-highlighter": "^15.5.11",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "@vitejs/plugin-react-swc": "^3.7.1",
    "browserslist": "^4.24.0",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "drizzle-kit": "^0.31.1",
    "eslint": "^9.15.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.12.0",
    "postcss": "^8.4.49",
    "sharp": "^0.34.4",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.15.0",
    "vite": "^5.4.11",
    "wrangler": "^4.20.5"
  },
  "overrides": {
    "caniuse-lite": "^1.0.30001766",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
