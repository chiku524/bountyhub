{
  "name": "bountyhub",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "wrangler dev --config wrangler.dev.toml --persist-to .wrangler/state",
    "dev:frontend": "vite",
    "dev:full": "concurrently \"npm run dev:api\" \"npm run dev:frontend\"",
    "dev:setup": "./scripts/dev-setup.sh",
    "dev:setup:win": "scripts\\dev-setup.bat",
    "build": "tsc && vite build",
    "build:api": "tsc --project functions/tsconfig.json",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "deploy:api": "wrangler deploy --config wrangler.workers.toml",
    "deploy:frontend": "wrangler pages deploy ./dist --project-name bountyhub",
    "deploy:frontend:local": "npm run build && wrangler pages deploy ./dist --project-name bountyhub",
    "deploy:workers": "wrangler deploy --config wrangler.workers.toml",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply bountyhub-db",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.31.1",
    "@solana/spl-token": "^0.4.13",
    "@solana/wallet-adapter-base": "^0.9.27",
    "@solana/wallet-adapter-phantom": "^0.9.28",
    "@solana/wallet-adapter-react": "^0.15.39",
    "@solana/wallet-adapter-react-ui": "^0.9.39",
    "@solana/wallet-adapter-solflare": "^0.6.32",
    "@solana/wallet-adapter-wallets": "^0.19.37",
    "@solana/web3.js": "^1.98.2",
    "bcryptjs": "2.4.3",
    "better-sqlite3": "^12.0.0",
    "cloudinary": "2.0.1",
    "drizzle-orm": "^0.44.2",
    "gsap": "3.12.5",
    "hono": "^4.8.2",
    "mongodb": "6.3.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet-async": "^2.0.5",
    "react-icons": "5.0.1",
    "react-router-dom": "^6.22.0",
    "react-syntax-highlighter": "15.5.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250620.0",
    "@types/bcryptjs": "2.4.6",
    "@types/bs58": "^4.0.4",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@types/react-syntax-highlighter": "^15.5.11",
    "@typescript-eslint/eslint-plugin": "^7.0.1",
    "@typescript-eslint/parser": "^7.0.1",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "drizzle-kit": "^0.31.1",
    "eslint": "^8.56.0",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.1.3",
    "wrangler": "^4.20.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
