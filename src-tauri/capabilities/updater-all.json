{
  "identifier": "updater-all",
  "description": "Grant updater plugin IPC on all windows/webviews (main + splash + any default webview label).",
  "local": true,
  "windows": ["*"],
  "webviews": ["*"],
  "permissions": [
    "updater:allow-check",
    "updater:allow-download",
    "updater:allow-install",
    "updater:allow-download-and-install"
  ]
}
