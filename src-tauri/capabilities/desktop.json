{
  "identifier": "desktop-capability",
  "description": "Dev server + bundled app: shortcuts, updater, tray-related IPC",
  "local": true,
  "platforms": [
    "macOS",
    "windows",
    "linux"
  ],
  "windows": [
    "main",
    "splashscreen"
  ],
  "permissions": [
    "global-shortcut:default",
    "updater:default"
  ],
  "remote": {
    "urls": [
      "http://localhost:5173/*",
      "http://127.0.0.1:5173/*",
      "https://tauri.localhost/*"
    ]
  }
}