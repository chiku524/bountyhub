{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "bundle": {
    "active": true,
    "category": "Productivity",
    "copyright": "",
    "targets": ["nsis", "dmg", "deb", "appimage"],
    "externalBin": [],
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "longDescription": "Decentralized bounty platform. Ask questions, offer bounties, earn rewards on Solana.",
    "macOS": {
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null
    },
    "resources": [],
    "shortDescription": "BountyHub desktop app",
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "createUpdaterArtifacts": "v1Compatible"
  },
  "productName": "BountyHub",
  "mainBinaryName": "BountyHub",
  "version": "1.1.42",
  "identifier": "tech.bountyhub.desktop",
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkyODJGNTAzMDQ4RkM2REQKUldUZHhvOEVBL1dDa3ZNNlJQVHhOUTFPazdpNXpON2lUQTNNWktNbEpQUUlsVUtmOEQ4aGV2cFcK",
      "endpoints": [
        "https://github.com/chiku524/bountyhub/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "quiet"
      }
    }
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "url": "/launch",
        "fullscreen": false,
        "decorations": true,
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "title": "BountyHub",
        "visible": false,
        "center": true,
        "useHttpsScheme": true
      },
      {
        "label": "splashscreen",
        "url": "/",
        "width": 420,
        "height": 320,
        "resizable": false,
        "decorations": false,
        "center": true,
        "visible": true,
        "title": "BountyHub",
        "useHttpsScheme": true
      }
    ],
    "security": {
      "capabilities": [
        "migrated",
        "desktop-capability",
        "updater-all"
      ],
      "csp": {
        "default-src": "'self' asset:",
        "connect-src": "ipc: http://ipc.localhost https://api.bountyhub.tech wss://api.bountyhub.tech http://127.0.0.1:8788 http://localhost:8788 https://bountyhub-api.nico-chikuji.workers.dev https://api.cloudinary.com https://api.giphy.com https://api.dicebear.com https://api.html2pdf.app https://api.mainnet-beta.solana.com",
        "font-src": ["https://fonts.gstatic.com"],
        "img-src": "'self' asset: http://asset.localhost blob: data: https: http:",
        "style-src": "'unsafe-inline' 'self' https://fonts.googleapis.com"
      }
    }
  }
}
