    "updater": {
      "active": true,
      "endpoints": ["https://github.com/chiku524/bountyhub/releases/latest/download/latest.json"],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkyODJGNTAzMDQ4RkM2REQKUldUZHhvOEVBL1dDa3ZNNlJQVHhOUTFPazdpNXpON2lUQTNNWktNbEpQUUlsVUtmOEQ4aGV2cFcK"
    },
    "windows": [
      {
        "label": "main",
        "fullscreen": false,
        "decorations": false,
        "width": 360,
        "height": 400,
        "minWidth": 280,
        "minHeight": 320,
        "resizable": true,
        "title": "BountyHub"
      }
    ]
  }
